# ==========================================
# Entornos Virtuales
# ==========================================
venv/
env/
ENV/

# ==========================================
# Archivos de caché compilados de Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Bases de datos SQLite y datos de instancia
# ==========================================
instance/
*.db
*.sqlite3

# ==========================================
# Variables de entorno y secretos
# ==========================================
.env
.flaskenv

# ==========================================
# Archivos del IDE (VS Code)
# ==========================================
.vscode/

# ==========================================
# Archivos del sistema operativo (Windows/Mac)
# ==========================================
Thumbs.db
Desktop.ini
.DS_Store

# ==========================================
# Archivos subidos o generados temporalmente
# ==========================================
app/static/uploads/
*.log